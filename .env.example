# ============================================================
# AVAITOR Casino — Environment Variables
# Copy this file to .env and fill in your values
# Use the SAME Supabase project for local & production
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Supabase (get from: supabase.com → project → settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT (Admin sessions — use a long random string)
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Admin (first admin account — set before running)
ADMIN_EMAIL=admin@avaitor.com
ADMIN_PASSWORD=Admin@12345

# CORS (your frontend URLs, comma separated)
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
